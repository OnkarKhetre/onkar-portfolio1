package com.dba.service;

import java.security.MessageDigest;
import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

import com.dba.connection.MysqlConnection;
import com.dba.models.AdminUser;

public class UserAdminService {

    public List<AdminUser> getAllUsers() throws Exception {

        List<AdminUser> users = new ArrayList<AdminUser>();

        String sql =
                "SELECT id, username, role, display_name, active, created_at " +
                "FROM app_users " +
                "ORDER BY active DESC, username ASC";

        Connection conn = null;
        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            conn = MysqlConnection.getConnection();
            ps = conn.prepareStatement(sql);
            rs = ps.executeQuery();

            while (rs.next()) {
                AdminUser user = new AdminUser();

                user.setId(rs.getLong("id"));
                user.setUsername(rs.getString("username"));
                user.setRole(rs.getString("role"));
                user.setDisplayName(rs.getString("display_name"));
                user.setActive(rs.getString("active"));
                user.setCreatedAt(rs.getTimestamp("created_at"));

                users.add(user);
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }

        return users;
    }

    public void createUser(String username,
                           String password,
                           String role,
                           String displayName) throws Exception {

        String sql =
                "INSERT INTO app_users " +
                "(username, password_hash, role, display_name, active, created_at) " +
                "VALUES (?, ?, ?, ?, 'Y', NOW())";

        Connection conn = null;
        PreparedStatement ps = null;

        try {
            conn = MysqlConnection.getConnection();
            ps = conn.prepareStatement(sql);

            ps.setString(1, cleanUsername(username));
            ps.setString(2, hashPassword(password));
            ps.setString(3, cleanRole(role));
            ps.setString(4, safe(displayName));

            ps.executeUpdate();

        } finally {
            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }
    }

    public void resetPassword(long id, String newPassword) throws Exception {

        String sql =
                "UPDATE app_users " +
                "SET password_hash = ? " +
                "WHERE id = ?";

        Connection conn = null;
        PreparedStatement ps = null;

        try {
            conn = MysqlConnection.getConnection();
            ps = conn.prepareStatement(sql);

            ps.setString(1, hashPassword(newPassword));
            ps.setLong(2, id);

            ps.executeUpdate();

        } finally {
            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }
    }

    public void updateRole(long id, String role) throws Exception {

        String sql =
                "UPDATE app_users " +
                "SET role = ? " +
                "WHERE id = ?";

        Connection conn = null;
        PreparedStatement ps = null;

        try {
            conn = MysqlConnection.getConnection();
            ps = conn.prepareStatement(sql);

            ps.setString(1, cleanRole(role));
            ps.setLong(2, id);

            ps.executeUpdate();

        } finally {
            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }
    }

    public void updateDisplayName(long id, String displayName) throws Exception {

        String sql =
                "UPDATE app_users " +
                "SET display_name = ? " +
                "WHERE id = ?";

        Connection conn = null;
        PreparedStatement ps = null;

        try {
            conn = MysqlConnection.getConnection();
            ps = conn.prepareStatement(sql);

            ps.setString(1, safe(displayName));
            ps.setLong(2, id);

            ps.executeUpdate();

        } finally {
            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }
    }

    public void setActive(long id, String active) throws Exception {

        String sql =
                "UPDATE app_users " +
                "SET active = ? " +
                "WHERE id = ?";

        Connection conn = null;
        PreparedStatement ps = null;

        try {
            conn = MysqlConnection.getConnection();
            ps = conn.prepareStatement(sql);

            ps.setString(1, "Y".equalsIgnoreCase(active) ? "Y" : "N");
            ps.setLong(2, id);

            ps.executeUpdate();

        } finally {
            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }
    }

    private String hashPassword(String password) throws Exception {

        if (password == null || password.trim().equals("")) {
            throw new Exception("Password cannot be empty.");
        }

        MessageDigest md = MessageDigest.getInstance("SHA-256");
        byte[] hashBytes = md.digest(password.getBytes("UTF-8"));

        StringBuilder sb = new StringBuilder();

        for (byte b : hashBytes) {
            sb.append(String.format("%02x", b));
        }

        return "SHA256:" + sb.toString();
    }

    private String cleanUsername(String username) throws Exception {

        if (username == null || username.trim().equals("")) {
            throw new Exception("Username cannot be empty.");
        }

        return username.trim();
    }

    private String cleanRole(String role) {

        if (role == null || role.trim().equals("")) {
            return "USER";
        }

        role = role.trim().toUpperCase();

        if ("ADMIN".equals(role)) {
            return "ADMIN";
        }

        if ("TEAM_LEAD".equals(role)) {
            return "TEAM_LEAD";
        }

        return "USER";
    }

    private String safe(String value) {
        if (value == null) {
            return "";
        }

        return value.trim();
    }
}