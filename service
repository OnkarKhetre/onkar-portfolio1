package com.dba.service;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;

import com.dba.connection.MysqlConnection;
import com.dba.models.loginuser;

public class UserService {

    /*
     * Emergency login works ONLY when MySQL login check fails due to DB/connection issue.
     * Change password before final deployment.
     */
    private static final String EMERGENCY_USERNAME = "emergency";
    private static final String EMERGENCY_PASSWORD = "Emergency@123";

    public loginuser validateUserFromDatabase(String username, String password) throws Exception {

        if (username == null || password == null) {
            return null;
        }

        String sql =
                "SELECT id, username, password_hash, role, display_name, active " +
                "FROM app_users " +
                "WHERE username = ? AND active = 'Y'";

        Connection conn = null;
        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            conn = MysqlConnection.getConnection();

            ps = conn.prepareStatement(sql);
            ps.setString(1, username.trim());

            rs = ps.executeQuery();

            if (rs.next()) {

                String storedPasswordHash = rs.getString("password_hash");

                if (PasswordUtil.passwordMatches(password, storedPasswordHash)) {

                    loginuser user = new loginuser();

                    user.setId(rs.getInt("id"));
                    user.setUsername(rs.getString("username"));
                    user.setRole(rs.getString("role"));
                    user.setDisplayName(rs.getString("display_name"));
                    user.setActive(rs.getString("active"));
                    user.setEmergencyLogin(false);

                    return user;
                }
            }

        } finally {
            if (rs != null) try { rs.close(); } catch (Exception e) {}
            if (ps != null) try { ps.close(); } catch (Exception e) {}
            MysqlConnection.closeConnection(conn);
        }

        return null;
    }

    public loginuser validateEmergencyUser(String username, String password) {

        if (username == null || password == null) {
            return null;
        }

        if (EMERGENCY_USERNAME.equals(username.trim())
                && EMERGENCY_PASSWORD.equals(password)) {

            loginuser user = new loginuser();

            user.setId(-1);
            user.setUsername(EMERGENCY_USERNAME);
            user.setRole("ADMIN");
            user.setDisplayName("Emergency Admin");
            user.setActive("Y");
            user.setEmergencyLogin(true);

            return user;
        }

        return null;
    }
}