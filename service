package com.dba.service;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

import com.dba.models.LockNode;

public class LockTreeService {

    public List<LockNode> getLockTree(Connection conn) throws Exception {
        
        List<LockNode> list = new ArrayList<LockNode>();

        // The query is broken down line-by-line for readability
        String sql = 
            "SELECT " +
            "    LEVEL AS lock_depth, " +
            "    inst_id, " +
            "    sid, " +
            "    serial#, " +
            "    username, " +
            "    osuser, " +
            "    program, " +
            "    blocking_instance, " +
            "    blocking_session, " +
            "    event, " +
            "    seconds_in_wait, " +
            "    sql_id " +
            "FROM " +
            "    gv$session " +
            "START WITH " +
            "    blocking_session IS NULL " +
            "    AND sid IN ( " +
            "        SELECT DISTINCT blocking_session " +
            "        FROM gv$session " +
            "        WHERE blocking_session IS NOT NULL " +
            "    ) " +
            "CONNECT BY PRIOR " +
            "    sid = blocking_session " +
            "    AND PRIOR inst_id = blocking_instance " +
            "ORDER SIBLINGS BY " +
            "    seconds_in_wait DESC";

        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            
            ps = conn.prepareStatement(sql);
            rs = ps.executeQuery();

            while (rs.next()) {
                
                LockNode node = new LockNode();
                
                node.setLevel(rs.getInt("lock_depth"));
                node.setInstId(rs.getString("inst_id"));
                node.setSid(rs.getString("sid"));
                node.setSerial(rs.getString("serial#"));
                
                node.setUsername(rs.getString("username"));
                node.setOsuser(rs.getString("osuser"));
                node.setProgram(rs.getString("program"));
                
                node.setBlockingInst(rs.getString("blocking_instance"));
                node.setBlockingSid(rs.getString("blocking_session"));
                
                node.setEvent(rs.getString("event"));
                node.setSecondsInWait(rs.getLong("seconds_in_wait"));
                node.setSqlId(rs.getString("sql_id"));

                // Build the kill command 
                String killCmd = buildKillCommand(
                    node.getSid(), 
                    node.getSerial(), 
                    node.getInstId()
                );
                
                node.setKillCommand(killCmd);

                list.add(node);
            }
            
        } finally {
            
            // Expanded try-catch blocks for clean resource closing
            if (rs != null) {
                try { 
                    rs.close(); 
                } catch (Exception e) {
                    e.printStackTrace();
                }
            }
            
            if (ps != null) {
                try { 
                    ps.close(); 
                } catch (Exception e) {
                    e.printStackTrace();
                }
            }
            
        }

        return list;
    }

    private String buildKillCommand(String sid, String serial, String instId) {
        
        if (sid == null || sid.trim().equals("") || 
            serial == null || serial.trim().equals("") || 
            instId == null || instId.trim().equals("")) {
            
            return "";
        }
        
        return "ALTER SYSTEM KILL SESSION '" + 
               sid.trim() + "," + 
               serial.trim() + ",@" + 
               instId.trim() + 
               "' IMMEDIATE;";
    }
}
