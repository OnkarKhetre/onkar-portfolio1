        return list;

    }





    public List<DrArchiveSequenceInfo> getArchiveSequence(Connection conn) throws Exception {


        List<DrArchiveSequenceInfo> list=new ArrayList<>();


        String sql =

                "SELECT " +
                "thread#, " +
                "MAX(sequence#) received_seq, " +
                "MAX(CASE WHEN applied='YES' THEN sequence# END) applied_seq " +
                "FROM v$archived_log " +
                "GROUP BY thread# " +
                "ORDER BY thread#";


        PreparedStatement ps=null;
        ResultSet rs=null;


        try {


            ps=conn.prepareStatement(sql);
            ps.setQueryTimeout(10);


            rs=ps.executeQuery();


            while(rs.next()) {


                DrArchiveSequenceInfo obj=new DrArchiveSequenceInfo();


                long received =
                        rs.getLong("received_seq");

                long applied =
                        rs.getLong("applied_seq");



                obj.setThreadNo(
                        rs.getString("thread#")
                );

                obj.setReceivedSeq(received);

                obj.setAppliedSeq(applied);

                obj.setGap(received-applied);



                list.add(obj);


            }


        } finally {

            close(rs, ps);

        }



        return list;


    }





    public List<DrArchiveDestInfo> getArchiveDestination(Connection conn) throws Exception {


        List<DrArchiveDestInfo> list=new ArrayList<>();


        String sql =

                "SELECT " +
                "dest_id, " +
                "status, " +
                "type, " +
                "database_mode, " +
                "recovery_mode, " +
                "destination, " +
                "error " +
                "FROM v$archive_dest_status " +
                "WHERE status <> 'INACTIVE'";



        PreparedStatement ps=null;
        ResultSet rs=null;


        try {


            ps=conn.prepareStatement(sql);
            ps.setQueryTimeout(10);


            rs=ps.executeQuery();


            while(rs.next()) {


                DrArchiveDestInfo obj=new DrArchiveDestInfo();


                obj.setDestId(rs.getString("dest_id"));
                obj.setStatus(rs.getString("status"));
                obj.setType(rs.getString("type"));
                obj.setDatabaseMode(rs.getString("database_mode"));
                obj.setRecoveryMode(rs.getString("recovery_mode"));
                obj.setDestination(rs.getString("destination"));
                obj.setError(rs.getString("error"));



                list.add(obj);


            }


        } finally {

            close(rs, ps);

        }


        return list;

    }





    private void close(ResultSet rs, PreparedStatement ps) {


        if(rs!=null){

            try{
                rs.close();
            }catch(Exception e){}

        }


        if(ps!=null){

            try{
                ps.close();
            }catch(Exception e){}

        }


    }

}