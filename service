package com.dba.service;

import java.sql.Connection;
import java.sql.Date;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

import com.dba.connection.MysqlConnection;
import com.dba.models.TeamLoginAudit;

public class TeamMonitorService {

    public void markMonitored(long loginAuditId, String remarks) throws Exception {

        String sql =
                "UPDATE login_audit " +
                "SET monitored = 'Y', monitored_at = NOW(), monitor_remarks = ? " +
                "WHERE id = ?";

        Connection conn = null;
        PreparedStatement ps = null;

        try {
            conn = MysqlConnection.getConnection();

            ps = conn.prepareStatement(sql);
            ps.setString(1, remarks);
            ps.setLong(2, loginAuditId);

            ps.executeUpdate();

        } finally {
            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }
    }

    public List<TeamLoginAudit> getTeamLogins(String dateFilter, String monitorFilter) throws Exception {

        List<TeamLoginAudit> list = new ArrayList<TeamLoginAudit>();

        String sql =
                "SELECT id, username, login_time, logout_time, ip_address, status, " +
                "monitored, monitored_at, monitor_remarks " +
                "FROM login_audit " +
                "WHERE DATE(login_time) = ? " +
                "AND status IN ('SUCCESS', 'EMERGENCY_SUCCESS') ";

        if ("Y".equalsIgnoreCase(monitorFilter)) {
            sql += "AND monitored = 'Y' ";
        } else if ("N".equalsIgnoreCase(monitorFilter)) {
            sql += "AND (monitored = 'N' OR monitored IS NULL) ";
        }

        sql += "ORDER BY login_time DESC, id DESC";

        Connection conn = null;
        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            conn = MysqlConnection.getConnection();

            ps = conn.prepareStatement(sql);
            ps.setDate(1, Date.valueOf(dateFilter));

            rs = ps.executeQuery();

            while (rs.next()) {
                TeamLoginAudit item = new TeamLoginAudit();

                item.setId(rs.getLong("id"));
                item.setUsername(rs.getString("username"));
                item.setLoginTime(rs.getTimestamp("login_time"));
                item.setLogoutTime(rs.getTimestamp("logout_time"));
                item.setIpAddress(rs.getString("ip_address"));
                item.setStatus(rs.getString("status"));
                item.setMonitored(rs.getString("monitored"));
                item.setMonitoredAt(rs.getTimestamp("monitored_at"));
                item.setMonitorRemarks(rs.getString("monitor_remarks"));

                list.add(item);
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }

        return list;
    }
}