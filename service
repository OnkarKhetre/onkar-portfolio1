package com.dba.service;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

import com.dba.models.DatafileInfo;

public class TablespaceDatafileService {

    public List<DatafileInfo> getDatafiles(Connection conn, String tablespaceName) throws Exception {

        List<DatafileInfo> list = new ArrayList<DatafileInfo>();

        if (tablespaceName == null || tablespaceName.trim().equals("")) {
            throw new Exception("Tablespace name is required.");
        }

        String tbs = tablespaceName.trim().toUpperCase();

        list.addAll(getPermanentDatafiles(conn, tbs));
        list.addAll(getTempFiles(conn, tbs));

        return list;
    }

    private List<DatafileInfo> getPermanentDatafiles(Connection conn, String tablespaceName) throws Exception {

        List<DatafileInfo> list = new ArrayList<DatafileInfo>();

        String sql =
                "SELECT " +
                "    df.tablespace_name, " +
                "    df.file_name, " +
                "    ROUND(df.bytes / 1024 / 1024 / 1024, 2) AS size_gb, " +
                "    df.autoextensible, " +
                "    ROUND(df.maxbytes / 1024 / 1024 / 1024, 2) AS max_size_gb, " +
                "    ROUND((df.increment_by * ts.block_size) / 1024 / 1024, 2) AS increment_mb, " +
                "    df.status " +
                "FROM dba_data_files df " +
                "JOIN dba_tablespaces ts " +
                "    ON df.tablespace_name = ts.tablespace_name " +
                "WHERE df.tablespace_name = ? " +
                "ORDER BY df.file_id";

        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            ps = conn.prepareStatement(sql);
            ps.setString(1, tablespaceName);

            rs = ps.executeQuery();

            while (rs.next()) {
                DatafileInfo item = new DatafileInfo();

                item.setTablespaceName(rs.getString("tablespace_name"));
                item.setFileName(rs.getString("file_name"));
                item.setFileType("DATAFILE");
                item.setSizeGb(rs.getDouble("size_gb"));
                item.setAutoExtensible(rs.getString("autoextensible"));
                item.setMaxSizeGb(rs.getDouble("max_size_gb"));
                item.setIncrementMb(rs.getDouble("increment_mb"));
                item.setStatus(rs.getString("status"));

                item.setAutoExtendCommand(buildAutoExtendCommand("DATAFILE", item.getFileName()));
                item.setResizeCommand(buildResizeCommand("DATAFILE", item.getFileName(), item.getSizeGb()));

                list.add(item);
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }
        }

        return list;
    }

    private List<DatafileInfo> getTempFiles(Connection conn, String tablespaceName) throws Exception {

        List<DatafileInfo> list = new ArrayList<DatafileInfo>();

        String sql =
                "SELECT " +
                "    tf.tablespace_name, " +
                "    tf.file_name, " +
                "    ROUND(tf.bytes / 1024 / 1024 / 1024, 2) AS size_gb, " +
                "    tf.autoextensible, " +
                "    ROUND(tf.maxbytes / 1024 / 1024 / 1024, 2) AS max_size_gb, " +
                "    ROUND((tf.increment_by * ts.block_size) / 1024 / 1024, 2) AS increment_mb, " +
                "    tf.status " +
                "FROM dba_temp_files tf " +
                "JOIN dba_tablespaces ts " +
                "    ON tf.tablespace_name = ts.tablespace_name " +
                "WHERE tf.tablespace_name = ? " +
                "ORDER BY tf.file_id";

        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            ps = conn.prepareStatement(sql);
            ps.setString(1, tablespaceName);

            rs = ps.executeQuery();

            while (rs.next()) {
                DatafileInfo item = new DatafileInfo();

                item.setTablespaceName(rs.getString("tablespace_name"));
                item.setFileName(rs.getString("file_name"));
                item.setFileType("TEMPFILE");
                item.setSizeGb(rs.getDouble("size_gb"));
                item.setAutoExtensible(rs.getString("autoextensible"));
                item.setMaxSizeGb(rs.getDouble("max_size_gb"));
                item.setIncrementMb(rs.getDouble("increment_mb"));
                item.setStatus(rs.getString("status"));

                item.setAutoExtendCommand(buildAutoExtendCommand("TEMPFILE", item.getFileName()));
                item.setResizeCommand(buildResizeCommand("TEMPFILE", item.getFileName(), item.getSizeGb()));

                list.add(item);
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }
        }

        return list;
    }

    public String buildAddDatafileCommand(String tablespaceName, String fileType) {

        if (tablespaceName == null || tablespaceName.trim().equals("")) {
            return "";
        }

        String tbs = tablespaceName.trim().toUpperCase();

        if ("TEMPFILE".equalsIgnoreCase(fileType)) {
            return "ALTER TABLESPACE " + tbs +
                    " ADD TEMPFILE '+DATA' SIZE 10G AUTOEXTEND ON NEXT 1G MAXSIZE 32G;";
        }

        return "ALTER TABLESPACE " + tbs +
                " ADD DATAFILE '+DATA' SIZE 10G AUTOEXTEND ON NEXT 1G MAXSIZE 32G;";
    }

    private String buildAutoExtendCommand(String fileType, String fileName) {

        if (fileName == null || fileName.trim().equals("")) {
            return "";
        }

        if ("TEMPFILE".equalsIgnoreCase(fileType)) {
            return "ALTER DATABASE TEMPFILE '" + fileName +
                    "' AUTOEXTEND ON NEXT 1G MAXSIZE 32G;";
        }

        return "ALTER DATABASE DATAFILE '" + fileName +
                "' AUTOEXTEND ON NEXT 1G MAXSIZE 32G;";
    }

    private String buildResizeCommand(String fileType, String fileName, double currentSizeGb) {

        if (fileName == null || fileName.trim().equals("")) {
            return "";
        }

        int suggestedSize = (int) Math.ceil(currentSizeGb + 10);

        if (suggestedSize < 10) {
            suggestedSize = 10;
        }

        if ("TEMPFILE".equalsIgnoreCase(fileType)) {
            return "ALTER DATABASE TEMPFILE '" + fileName +
                    "' RESIZE " + suggestedSize + "G;";
        }

        return "ALTER DATABASE DATAFILE '" + fileName +
                "' RESIZE " + suggestedSize + "G;";
    }
}