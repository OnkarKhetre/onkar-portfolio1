package com.dba.service;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

import com.dba.models.DrArchiveDestInfo;
import com.dba.models.DrArchiveSequenceInfo;
import com.dba.models.DrDatabaseInfo;
import com.dba.models.DrLagInfo;
import com.dba.models.DrManagedProcessInfo;

public class DrHealthMonitorService {


    public DrDatabaseInfo getDatabaseInfo(Connection conn) throws Exception {

        DrDatabaseInfo info = new DrDatabaseInfo();

        String sql =
                "SELECT database_role, " +
                "open_mode, " +
                "protection_mode, " +
                "protection_level, " +
                "switchover_status " +
                "FROM v$database";


        PreparedStatement ps = null;
        ResultSet rs = null;

        try {

            ps = conn.prepareStatement(sql);
            ps.setQueryTimeout(10);

            rs = ps.executeQuery();

            if(rs.next()) {

                info.setDatabaseRole(rs.getString("database_role"));
                info.setOpenMode(rs.getString("open_mode"));
                info.setProtectionMode(rs.getString("protection_mode"));
                info.setProtectionLevel(rs.getString("protection_level"));
                info.setSwitchoverStatus(rs.getString("switchover_status"));

            }

        } finally {
            close(rs, ps);
        }


        return info;
    }



    public List<DrManagedProcessInfo> getManagedProcesses(Connection conn) throws Exception {


        List<DrManagedProcessInfo> list = new ArrayList<>();


        String sql =
                "SELECT process, " +
                "status, " +
                "thread#, " +
                "sequence#, " +
                "block#, " +
                "blocks, " +
                "client_process " +
                "FROM v$managed_standby " +
                "ORDER BY process";


        PreparedStatement ps=null;
        ResultSet rs=null;


        try {

            ps=conn.prepareStatement(sql);
            ps.setQueryTimeout(10);

            rs=ps.executeQuery();


            while(rs.next()) {


                DrManagedProcessInfo obj = new DrManagedProcessInfo();


                obj.setProcess(rs.getString("process"));
                obj.setStatus(rs.getString("status"));
                obj.setThreadNo(rs.getString("thread#"));
                obj.setSequenceNo(rs.getString("sequence#"));
                obj.setBlockNo(rs.getString("block#"));
                obj.setBlocks(rs.getString("blocks"));
                obj.setClientProcess(rs.getString("client_process"));


                list.add(obj);

            }


        } finally {

            close(rs, ps);

        }


        return list;

    }




    public List<DrLagInfo> getLagInfo(Connection conn) throws Exception {


        List<DrLagInfo> list = new ArrayList<>();


        String sql =
                "SELECT name, value, unit, time_computed " +
                "FROM v$dataguard_stats";


        PreparedStatement ps=null;
        ResultSet rs=null;


        try {


            ps=conn.prepareStatement(sql);
            ps.setQueryTimeout(10);


            rs=ps.executeQuery();


            while(rs.next()) {


                DrLagInfo obj=new DrLagInfo();


                obj.setName(rs.getString("name"));
                obj.setValue(rs.getString("value"));
                obj.setUnit(rs.getString("unit"));
                obj.setTimeComputed(rs.getString("time_computed"));


                list.add(obj);


            }



        } finally {

            close(rs, ps);

