package com.dba.service;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

import com.dba.connection.MysqlConnection;
import com.dba.models.TaskPerformance;

public class TaskPerformanceService {

    public List<TaskPerformance> getPerformance(String fromDate, String toDate, String userFilter) throws Exception {

        List<TaskPerformance> list = new ArrayList<TaskPerformance>();

        String sql =
            "SELECT u.username, " +

            "SUM(CASE WHEN t.created_by = u.username THEN 1 ELSE 0 END) AS created_tasks, " +

            "SUM(CASE WHEN t.assigned_to = u.username THEN 1 ELSE 0 END) AS assigned_tasks, " +

            "SUM(CASE WHEN t.completed_by = u.username THEN 1 ELSE 0 END) AS completed_tasks, " +

            "SUM(CASE WHEN t.assigned_to = u.username AND t.status <> 'DONE' AND t.status <> 'CANCELLED' THEN 1 ELSE 0 END) AS pending_tasks, " +

            "SUM(CASE WHEN t.completed_by = u.username AND t.priority = 'CRITICAL' THEN 1 ELSE 0 END) AS critical_completed, " +

            "SUM(CASE WHEN t.completed_by = u.username AND t.priority = 'HIGH' THEN 1 ELSE 0 END) AS high_completed, " +

            "SUM(CASE WHEN t.assigned_to = u.username THEN IFNULL(t.reassign_count,0) ELSE 0 END) AS total_reassign_count, " +

            "IFNULL(AVG(CASE WHEN t.completed_by = u.username AND t.completed_at IS NOT NULL " +
            "THEN TIMESTAMPDIFF(MINUTE, t.created_at, t.completed_at) END),0) AS avg_completion_minutes " +

            "FROM app_users u " +
            "LEFT JOIN task_items t ON " +
            "(t.created_by = u.username OR t.assigned_to = u.username OR t.completed_by = u.username) ";

        List<String> params = new ArrayList<String>();

        sql += "WHERE u.active = 'Y' ";

        if (fromDate != null && fromDate.trim().length() > 0) {
            sql += "AND DATE(IFNULL(t.created_at, NOW())) >= ? ";
            params.add(fromDate.trim());
        }

        if (toDate != null && toDate.trim().length() > 0) {
            sql += "AND DATE(IFNULL(t.created_at, NOW())) <= ? ";
            params.add(toDate.trim());
        }

        if (userFilter != null && userFilter.trim().length() > 0 && !"ALL".equalsIgnoreCase(userFilter)) {
            sql += "AND u.username = ? ";
            params.add(userFilter.trim());
        }

        sql += "GROUP BY u.username ORDER BY completed_tasks DESC, pending_tasks ASC, u.username";

        Connection conn = null;
        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            conn = MysqlConnection.getConnection();
            ps = conn.prepareStatement(sql);

            for (int i = 0; i < params.size(); i++) {
                ps.setString(i + 1, params.get(i));
            }

            rs = ps.executeQuery();

            while (rs.next()) {
                TaskPerformance p = new TaskPerformance();

                p.setUsername(rs.getString("username"));
                p.setCreatedTasks(rs.getInt("created_tasks"));
                p.setAssignedTasks(rs.getInt("assigned_tasks"));
                p.setCompletedTasks(rs.getInt("completed_tasks"));
                p.setPendingTasks(rs.getInt("pending_tasks"));
                p.setCriticalCompleted(rs.getInt("critical_completed"));
                p.setHighCompleted(rs.getInt("high_completed"));
                p.setTotalReassignCount(rs.getInt("total_reassign_count"));

                double minutes = rs.getDouble("avg_completion_minutes");
                p.setAvgCompletionHours(minutes / 60.0);

                list.add(p);
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }

        return list;
    }

    public List<String> getActiveUsers() throws Exception {

        List<String> users = new ArrayList<String>();

        String sql = "SELECT username FROM app_users WHERE active = 'Y' ORDER BY username";

        Connection conn = null;
        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            conn = MysqlConnection.getConnection();
            ps = conn.prepareStatement(sql);
            rs = ps.executeQuery();

            while (rs.next()) {
                users.add(rs.getString("username"));
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }

            MysqlConnection.closeConnection(conn);
        }

        return users;
    }
}