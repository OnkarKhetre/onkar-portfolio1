package com.dba.service;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

import com.dba.models.BlockingSessionInfo;
import com.dba.models.LongOperationInfo;
import com.dba.models.LongRunningSessionInfo;

public class SessionMonitorService {

    public List<BlockingSessionInfo> getBlockingSessions(Connection conn) throws Exception {

        List<BlockingSessionInfo> list = new ArrayList<BlockingSessionInfo>();

        String sql =
                "SELECT " +
                "    s.inst_id AS blocked_inst_id, " +
                "    s.sid AS blocked_sid, " +
                "    s.serial# AS blocked_serial, " +
                "    b.inst_id AS blocker_inst_id, " +
                "    b.sid AS blocker_sid, " +
                "    b.serial# AS blocker_serial, " +
                "    s.username, " +
                "    s.machine, " +
                "    s.program, " +
                "    s.module, " +
                "    s.status, " +
                "    s.event, " +
                "    s.wait_class, " +
                "    s.seconds_in_wait, " +
                "    s.sql_id " +
                "FROM gv$session s " +
                "LEFT JOIN gv$session b " +
                "    ON b.inst_id = s.blocking_instance " +
                "   AND b.sid = s.blocking_session " +
                "WHERE s.blocking_session IS NOT NULL " +
                "ORDER BY s.seconds_in_wait DESC";

        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            ps = conn.prepareStatement(sql);
            rs = ps.executeQuery();

            while (rs.next()) {
                BlockingSessionInfo item = new BlockingSessionInfo();

                item.setBlockedInstId(rs.getString("blocked_inst_id"));
                item.setBlockedSid(rs.getString("blocked_sid"));
                item.setBlockedSerial(rs.getString("blocked_serial"));

                item.setBlockerInstId(rs.getString("blocker_inst_id"));
                item.setBlockerSid(rs.getString("blocker_sid"));
                item.setBlockerSerial(rs.getString("blocker_serial"));

                item.setUsername(rs.getString("username"));
                item.setMachine(rs.getString("machine"));
                item.setProgram(rs.getString("program"));
                item.setModule(rs.getString("module"));
                item.setStatus(rs.getString("status"));
                item.setEvent(rs.getString("event"));
                item.setWaitClass(rs.getString("wait_class"));
                item.setSecondsInWait(rs.getLong("seconds_in_wait"));
                item.setSqlId(rs.getString("sql_id"));

                item.setKillCommand(
                        buildKillCommand(
                                item.getBlockerSid(),
                                item.getBlockerSerial(),
                                item.getBlockerInstId()
                        )
                );

                list.add(item);
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }
        }

        return list;
    }

    public List<LongRunningSessionInfo> getLongRunningSessions(Connection conn, int minimumMinutes) throws Exception {

        List<LongRunningSessionInfo> list = new ArrayList<LongRunningSessionInfo>();

        if (minimumMinutes <= 0) {
            minimumMinutes = 15;
        }

        String sql =
                "SELECT " +
                "    inst_id, " +
                "    sid, " +
                "    serial#, " +
                "    username, " +
                "    status, " +
                "    machine, " +
                "    program, " +
                "    module, " +
                "    event, " +
                "    wait_class, " +
                "    sql_id, " +
                "    last_call_et, " +
                "    logon_time " +
                "FROM gv$session " +
                "WHERE username IS NOT NULL " +
                "AND type = 'USER' " +
                "AND status = 'ACTIVE' " +
                "AND last_call_et >= ? " +
                "ORDER BY last_call_et DESC";

        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            ps = conn.prepareStatement(sql);
            ps.setInt(1, minimumMinutes * 60);

            rs = ps.executeQuery();

            while (rs.next()) {
                LongRunningSessionInfo item = new LongRunningSessionInfo();

                item.setInstId(rs.getString("inst_id"));
                item.setSid(rs.getString("sid"));
                item.setSerial(rs.getString("serial#"));
                item.setUsername(rs.getString("username"));
                item.setStatus(rs.getString("status"));
                item.setMachine(rs.getString("machine"));
                item.setProgram(rs.getString("program"));
                item.setModule(rs.getString("module"));
                item.setEvent(rs.getString("event"));
                item.setWaitClass(rs.getString("wait_class"));
                item.setSqlId(rs.getString("sql_id"));
                item.setLastCallEt(rs.getLong("last_call_et"));
                item.setLogonTime(rs.getTimestamp("logon_time"));

                item.setKillCommand(
                        buildKillCommand(
                                item.getSid(),
                                item.getSerial(),
                                item.getInstId()
                        )
                );

                list.add(item);
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }
        }

        return list;
    }

    public List<LongOperationInfo> getLongOperations(Connection conn) throws Exception {

        List<LongOperationInfo> list = new ArrayList<LongOperationInfo>();

        String sql =
                "SELECT " +
                "    inst_id, " +
                "    sid, " +
                "    serial#, " +
                "    username, " +
                "    opname, " +
                "    target, " +
                "    sql_id, " +
                "    sofar, " +
                "    totalwork, " +
                "    CASE " +
                "        WHEN totalwork > 0 THEN ROUND((sofar / totalwork) * 100, 2) " +
                "        ELSE 0 " +
                "    END AS percent_done, " +
                "    elapsed_seconds, " +
                "    time_remaining " +
                "FROM gv$session_longops " +
                "WHERE totalwork > 0 " +
                "AND sofar < totalwork " +
                "ORDER BY elapsed_seconds DESC";

        PreparedStatement ps = null;
        ResultSet rs = null;

        try {
            ps = conn.prepareStatement(sql);
            rs = ps.executeQuery();

            while (rs.next()) {
                LongOperationInfo item = new LongOperationInfo();

                item.setInstId(rs.getString("inst_id"));
                item.setSid(rs.getString("sid"));
                item.setSerial(rs.getString("serial#"));
                item.setUsername(rs.getString("username"));
                item.setOpname(rs.getString("opname"));
                item.setTarget(rs.getString("target"));
                item.setSqlId(rs.getString("sql_id"));
                item.setSofar(rs.getLong("sofar"));
                item.setTotalwork(rs.getLong("totalwork"));
                item.setPercentDone(rs.getDouble("percent_done"));
                item.setElapsedSeconds(rs.getLong("elapsed_seconds"));
                item.setTimeRemainingSeconds(rs.getLong("time_remaining"));

                list.add(item);
            }

        } finally {
            if (rs != null) {
                try { rs.close(); } catch (Exception e) {}
            }

            if (ps != null) {
                try { ps.close(); } catch (Exception e) {}
            }
        }

        return list;
    }

    private String buildKillCommand(String sid, String serial, String instId) {

        if (sid == null || sid.trim().equals("")
                || serial == null || serial.trim().equals("")
                || instId == null || instId.trim().equals("")) {
            return "";
        }

        return "ALTER SYSTEM KILL SESSION '"
                + sid.trim()
                + ","
                + serial.trim()
                + ",@"
                + instId.trim()
                + "' IMMEDIATE;";
    }
}