private long getTaskIdByActiveKey(Connection conn, String activeKey) throws Exception {

    String sql = "SELECT id FROM task_items WHERE active_key = ? LIMIT 1";

    PreparedStatement ps = null;
    ResultSet rs = null;

    try {
        ps = conn.prepareStatement(sql);
        ps.setString(1, activeKey);

        rs = ps.executeQuery();

        if (rs.next()) {
            return rs.getLong("id");
        }

    } finally {
        if (rs != null) {
            try { rs.close(); } catch (Exception e) {}
        }

        if (ps != null) {
            try { ps.close(); } catch (Exception e) {}
        }
    }

    return -1;
}



private String safeText(String value) {
    if (value == null) {
        return "";
    }

    return value.trim();
}

private String normalizePriority(String value) {

    String priority = clean(value);

    if ("CRITICAL".equalsIgnoreCase(priority)) {
        return "CRITICAL";
    }

    if ("HIGH".equalsIgnoreCase(priority)) {
        return "HIGH";
    }

    return "NORMAL";
}

