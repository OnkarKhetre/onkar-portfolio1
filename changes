function markDashboardMonitored(){
    var remarks = prompt("Enter monitoring remarks:", "Dashboard monitored");

    if(remarks === null){
        return;
    }

    var xhr = new XMLHttpRequest();
    xhr.open("POST", "<%= request.getContextPath() %>/markmonitor", true);
    xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");

    xhr.onreadystatechange = function(){
        if(xhr.readyState === 4){
            if(xhr.status === 200){
                var btn = document.getElementById("monitorBtn");
                if(btn){
                    btn.innerHTML = "✅ Monitored";
                    btn.disabled = true;
                    btn.style.opacity = "0.8";
                    btn.style.cursor = "default";
                }

                alert("Monitoring marked successfully.");
            }else{
                alert("Failed to mark monitoring: " + xhr.responseText);
            }
        }
    };

    xhr.send("remarks=" + encodeURIComponent(remarks));
}