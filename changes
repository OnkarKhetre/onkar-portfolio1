public Map<String, Integer> getOpenShiftTaskSummary(String shiftCode) throws Exception {

    Map<String, Integer> summary = new HashMap<String, Integer>();

    summary.put("TOTAL", 0);
    summary.put("CRITICAL", 0);
    summary.put("HIGH", 0);
    summary.put("NORMAL", 0);

    String sql =
            "SELECT " +
            "COUNT(*) AS total_count, " +
            "SUM(CASE WHEN priority = 'CRITICAL' THEN 1 ELSE 0 END) AS critical_count, " +
            "SUM(CASE WHEN priority = 'HIGH' THEN 1 ELSE 0 END) AS high_count, " +
            "SUM(CASE WHEN priority = 'NORMAL' THEN 1 ELSE 0 END) AS normal_count " +
            "FROM task_items " +
            "WHERE source_type = 'NOTIFICATION' " +
            "AND shift_code = ? " +
            "AND status = 'OPEN' " +
            "AND (assigned_to IS NULL OR assigned_to = '')";

    Connection conn = null;
    PreparedStatement ps = null;
    ResultSet rs = null;

    try {
        conn = MysqlConnection.getConnection();
        ps = conn.prepareStatement(sql);
        ps.setString(1, shiftCode);

        rs = ps.executeQuery();

        if (rs.next()) {
            summary.put("TOTAL", rs.getInt("total_count"));
            summary.put("CRITICAL", rs.getInt("critical_count"));
            summary.put("HIGH", rs.getInt("high_count"));
            summary.put("NORMAL", rs.getInt("normal_count"));
        }

    } finally {
        if (rs != null) {
            try { rs.close(); } catch (Exception e) {}
        }

        if (ps != null) {
            try { ps.close(); } catch (Exception e) {}
        }

        MysqlConnection.closeConnection(conn);
    }

    return summary;
}