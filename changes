private String getSqlTextAnyInstance(Connection conn, String sqlId) throws Exception {

    String sql =
            "SELECT sql_text " +
            "FROM ( " +
            "    SELECT DBMS_LOB.SUBSTR(sql_fulltext, 4000, 1) AS sql_text, last_active_time " +
            "    FROM gv$sql " +
            "    WHERE sql_id = ? " +
            "    ORDER BY last_active_time DESC " +
            ") " +
            "WHERE ROWNUM = 1";

    PreparedStatement ps = null;
    ResultSet rs = null;

    try {
        ps = conn.prepareStatement(sql);
        ps.setString(1, sqlId.trim());

        rs = ps.executeQuery();

        if (rs.next()) {
            return rs.getString("sql_text");
        }

    } finally {
        if (rs != null) {
            try { rs.close(); } catch (Exception e) {}
        }

        if (ps != null) {
            try { ps.close(); } catch (Exception e) {}
        }
    }

    return null;
}