package com.dba.models;

import java.sql.Timestamp;

public class LongRunningSessionInfo {

    private String instId;
    private String sid;
    private String serial;

    private String username;
    private String status;
    private String machine;
    private String program;
    private String module;

    private String event;
    private String waitClass;
    private String sqlId;

    private long lastCallEt;
    private Timestamp logonTime;

    private String killCommand;

    public String getInstId() {
        return instId;
    }

    public void setInstId(String instId) {
        this.instId = instId;
    }

    public String getSid() {
        return sid;
    }

    public void setSid(String sid) {
        this.sid = sid;
    }

    public String getSerial() {
        return serial;
    }

    public void setSerial(String serial) {
        this.serial = serial;
    }

    public String getUsername() {
        return username;
    }

    public void setUsername(String username) {
        this.username = username;
    }

    public String getStatus() {
        return status;
    }

    public void setStatus(String status) {
        this.status = status;
    }

    public String getMachine() {
        return machine;
    }

    public void setMachine(String machine) {
        this.machine = machine;
    }

    public String getProgram() {
        return program;
    }

    public void setProgram(String program) {
        this.program = program;
    }

    public String getModule() {
        return module;
    }

    public void setModule(String module) {
        this.module = module;
    }

    public String getEvent() {
        return event;
    }

    public void setEvent(String event) {
        this.event = event;
    }

    public String getWaitClass() {
        return waitClass;
    }

    public void setWaitClass(String waitClass) {
        this.waitClass = waitClass;
    }

    public String getSqlId() {
        return sqlId;
    }

    public void setSqlId(String sqlId) {
        this.sqlId = sqlId;
    }

    public long getLastCallEt() {
        return lastCallEt;
    }

    public void setLastCallEt(long lastCallEt) {
        this.lastCallEt = lastCallEt;
    }

    public Timestamp getLogonTime() {
        return logonTime;
    }

    public void setLogonTime(Timestamp logonTime) {
        this.logonTime = logonTime;
    }

    public String getKillCommand() {
        return killCommand;
    }

    public void setKillCommand(String killCommand) {
        this.killCommand = killCommand;
    }
}