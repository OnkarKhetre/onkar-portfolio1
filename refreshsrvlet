package com.dba.controller;

import java.io.IOException;
import java.util.Map;

import com.dba.service.ShiftRosterService;
import com.dba.service.TaskService;

import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import jakarta.servlet.http.HttpSession;

@WebServlet("/shifttasksummary")
public class ShiftTaskSummaryServlet extends HttpServlet {
    private static final long serialVersionUID = 1L;

    private TaskService taskService = new TaskService();
    private ShiftRosterService shiftRosterService = new ShiftRosterService();

    protected void doGet(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {

        response.setContentType("text/html;charset=UTF-8");
        response.setHeader("Cache-Control", "no-store, no-cache, must-revalidate, max-age=0");

        HttpSession session = request.getSession(false);

        if (session == null || session.getAttribute("loggedUser") == null) {
            response.setStatus(HttpServletResponse.SC_UNAUTHORIZED);
            response.getWriter().write("");
            return;
        }

        try {
            String currentShift = shiftRosterService.getCurrentShiftCode();

            Map<String, Integer> summary =
                    taskService.getOpenShiftTaskSummary(currentShift);

            int total = summary.get("TOTAL");
            int critical = summary.get("CRITICAL");
            int high = summary.get("HIGH");
            int normal = summary.get("NORMAL");

            String ctx = request.getContextPath();

            if (total <= 0) {
                response.getWriter().write(
                        "<div class='shift-task-mini ok'>" +
                            "<div class='shift-task-left'>" +
                                "<div class='shift-task-icon'>✅</div>" +
                                "<div>" +
                                    "<div class='shift-task-title'>No Pending Shift Tasks</div>" +
                                    "<div class='shift-task-sub'>Current shift: " + currentShift + "</div>" +
                                "</div>" +
                            "</div>" +
                        "</div>"
                );
                return;
            }

            response.getWriter().write(
                    "<div class='shift-task-mini alert'>" +
                        "<div class='shift-task-left'>" +
                            "<div class='shift-task-icon'>📌</div>" +
                            "<div>" +
                                "<div class='shift-task-title'>Current Shift Tasks: " + total + "</div>" +
                                "<div class='shift-task-sub'>" +
                                    "Shift: " + currentShift +
                                    " | Critical: " + critical +
                                    " | High: " + high +
                                    " | Normal: " + normal +
                                "</div>" +
                            "</div>" +
                        "</div>" +
                        "<a class='shift-task-open' href='" + ctx + "/taskmanager?status=OPEN&assignedTo=UNASSIGNED&shift=CURRENT'>Open</a>" +
                    "</div>"
            );

        } catch (Exception e) {
            e.printStackTrace();

            response.getWriter().write(
                    "<div class='shift-task-mini error-mini'>" +
                        "<div class='shift-task-left'>" +
                            "<div class='shift-task-icon'>⚠️</div>" +
                            "<div>" +
                                "<div class='shift-task-title'>Shift task summary failed</div>" +
                                "<div class='shift-task-sub'>" + safe(e.getMessage()) + "</div>" +
                            "</div>" +
                        "</div>" +
                    "</div>"
            );
        }
    }

    private String safe(String value) {
        if (value == null) {
            return "";
        }

        return value
                .replace("&", "&amp;")
                .replace("<", "&lt;")
                .replace(">", "&gt;")
                .replace("\"", "&quot;");
    }
}