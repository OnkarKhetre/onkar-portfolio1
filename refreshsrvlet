protected void doGet(HttpServletRequest request, HttpServletResponse response)
        throws ServletException, IOException {

    HttpSession session = request.getSession();

    DashboardTabUtil.addOrUpdateTab(
            session,
            TAB_ID,
            "GG Lag",
            "gglag",
            true
    );

    DashboardTabUtil.setActiveTab(session, TAB_ID);

    String reload = request.getParameter("reload");
    String ajax = request.getParameter("ajax");

    String currentStatus = (String) session.getAttribute("ggLagStatus");

    boolean shouldStart =
            "true".equalsIgnoreCase(reload)
            || currentStatus == null
            || "ERROR".equalsIgnoreCase(currentStatus);

    if (shouldStart || !"RUNNING".equalsIgnoreCase(currentStatus)) {
        startGgLagJob(session);
    }

    /*
     * IMPORTANT:
     * Ajax reload should NOT forward to index.jsp.
     * It should only start background job and return OK.
     */
    if ("true".equalsIgnoreCase(ajax)) {
        response.setContentType("text/plain");
        response.getWriter().write("OK");
        return;
    }

    request.setAttribute("activePage", "gglag");
    request.setAttribute("status", "GG Lag loading from PR-ARCHIVALDB");

    request.getRequestDispatcher("index.jsp").forward(request, response);
}