package com.dba.controller;

import java.io.IOException;
import java.sql.Connection;
import java.util.ArrayList;
import java.util.List;

import com.dba.config.DatabaseRegistry;
import com.dba.connection.databaseconnection;
import com.dba.models.BlockingSessionInfo;
import com.dba.models.LongOperationInfo;
import com.dba.models.LongRunningSessionInfo;
import com.dba.service.SessionMonitorService;

import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import jakarta.servlet.http.HttpSession;

@WebServlet("/sessionmonitor")
public class SessionMonitorServlet extends HttpServlet {
    private static final long serialVersionUID = 1L;

    private SessionMonitorService service = new SessionMonitorService();

    @Override
    protected void doGet(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {

        if (!isLoggedIn(request)) {
            response.sendRedirect(request.getContextPath() + "/login.jsp");
            return;
        }

        String site = request.getParameter("site");
        String target = request.getParameter("target");
        String run = request.getParameter("run");

        int minMinutes = parseInt(request.getParameter("minMinutes"), 15);

        List<BlockingSessionInfo> blockingSessions = new ArrayList<BlockingSessionInfo>();
        List<LongRunningSessionInfo> longRunningSessions = new ArrayList<LongRunningSessionInfo>();
        List<LongOperationInfo> longOperations = new ArrayList<LongOperationInfo>();

        Connection conn = null;

        try {
            if ("Y".equalsIgnoreCase(run)) {

                if (site == null || site.trim().equals("")
                        || target == null || target.trim().equals("")) {
                    throw new Exception("Please select database.");
                }

                conn = databaseconnection.getconnection(site, target);

                if (conn == null) {
                    throw new Exception("Could not connect to selected database.");
                }

                blockingSessions = service.getBlockingSessions(conn);
                longRunningSessions = service.getLongRunningSessions(conn, minMinutes);
                longOperations = service.getLongOperations(conn);
            }

            request.setAttribute("blockingSessions", blockingSessions);
            request.setAttribute("longRunningSessions", longRunningSessions);
            request.setAttribute("longOperations", longOperations);

            request.setAttribute("site", site);
            request.setAttribute("target", target);
            request.setAttribute("minMinutes", minMinutes);
            request.setAttribute("run", run);

            request.setAttribute("dbList", DatabaseRegistry.ALL_DATABASES);

            request.getRequestDispatcher("/sessionmonitor.jsp").forward(request, response);

        } catch (Exception e) {
            e.printStackTrace();

            request.setAttribute("errorMsg", e.getMessage());

            request.setAttribute("blockingSessions", blockingSessions);
            request.setAttribute("longRunningSessions", longRunningSessions);
            request.setAttribute("longOperations", longOperations);

            request.setAttribute("site", site);
            request.setAttribute("target", target);
            request.setAttribute("minMinutes", minMinutes);
            request.setAttribute("run", run);

            request.setAttribute("dbList", DatabaseRegistry.ALL_DATABASES);

            request.getRequestDispatcher("/sessionmonitor.jsp").forward(request, response);

        } finally {
            if (conn != null) {
                try {
                    databaseconnection.closeconnection(conn);
                } catch (Exception e) {
                    e.printStackTrace();
                }
            }
        }
    }

    private boolean isLoggedIn(HttpServletRequest request) {

        HttpSession session = request.getSession(false);

        if (session == null) {
            return false;
        }

        return session.getAttribute("loggedUser") != null;
    }

    private int parseInt(String value, int defaultValue) {

        try {
            if (value == null || value.trim().equals("")) {
                return defaultValue;
            }

            return Integer.parseInt(value);

        } catch (Exception e) {
            return defaultValue;
        }
    }
}