@WebServlet("/refreshstats")
public class RefreshStatServlet extends HttpServlet {
    private static final long serialVersionUID = 1L;

    private static final String[][] FIXED_DBS = {
        {"PR", "MIDB"},
        {"PR", "HIDB"},
        {"PR", "REPORTDB"},
        {"PR", "SBISIDB"},
        {"PR", "ARCHIVALDB"},
        {"DR", "MIDB"}
    };

    protected void doGet(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {

        dbaqueryservice service = new dbaqueryservice();

        Map<String, Object> dashboardData = new LinkedHashMap<>();

        for (String[] db : FIXED_DBS) {
            String site = db[0];
            String target = db[1];
            String key = site + "-" + target;

            Map<String, Object> stats = new HashMap<>();
            Connection conn = null;

            try {
                conn = databaseconnection.getconnection(site, target);

                stats.put("size", service.getdbsize(conn));
                stats.put("fra", service.getfrausage(conn));
                stats.put("instanceinfo", service.getinstancestats(conn));
                stats.put("activesession", service.getactivesession(conn));
                stats.put("archives", service.getarchives(conn));
                stats.put("thread", service.getarchivethread(conn));
                stats.put("status", "OK");

            } catch (Exception e) {
                e.printStackTrace();
                stats.put("status", "ERROR");
                stats.put("error", e.getMessage());
            } finally {
                databaseconnection.closeconnection(conn);
            }

            dashboardData.put(key, stats);
        }

        request.setAttribute("fulldata", dashboardData);
        request.getRequestDispatcher("index.jsp").forward(request, response);
    }

    protected void doPost(HttpServletRequest request, HttpServletResponse response)
            throws ServletException